#include <stdio.h>
#include <stdbool.h>
#include <stdlib.h>
#include <string.h>

char str_numbers[100000][5];

int compare(const void* a, const void* b) {
    char* s1 = *(char**)a;
    char* s2 = *(char**)b;

    char ab[10];
    char ba[10];

    strcpy(ab, s1);
    strcat(ab, s2);

    strcpy(ba, s2);
    strcat(ba, s1);

    return strcmp(ba, ab);  
}

// numbers_len은 배열 numbers의 길이입니다.
char* solution(int numbers[], size_t numbers_len) {
    char** arr = (char**)malloc(numbers_len * sizeof(char*));

    for (size_t i = 0; i < numbers_len; i++) {
        sprintf(str_numbers[i], "%d", numbers[i]);
        arr[i] = str_numbers[i];
    }

    qsort(arr, numbers_len, sizeof(char*), compare);

    if (strcmp(arr[0], "0") == 0) {
        char* answer = (char*)malloc(2);
        strcpy(answer, "0");
        free(arr);
        return answer;
    }

    size_t total_len = 0;
    for (size_t i = 0; i < numbers_len; i++) {
        total_len += strlen(arr[i]);
    }

    char* answer = (char*)malloc(total_len + 1);
    answer[0] = '\0';

    for (size_t i = 0; i < numbers_len; i++) {
        strcat(answer, arr[i]);
    }

    free(arr);
    return answer;
}
